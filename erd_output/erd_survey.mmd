%% Category: survey (4 tables)
erDiagram
    tb_survey {
        int id
        varchar_255_ title
        text description
        varchar_128_ category
        varchar_100_ regulator
        int version
        tinyint status
        datetime start_time
        datetime end_time
        int priority
        datetime create_time
        datetime update_time
        int update_by
        tinyint is_del
