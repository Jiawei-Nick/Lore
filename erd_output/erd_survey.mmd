        json option_ids
        json option_pkeys
        text text_answer
        decimal_10_2_ numeric_answer
        int score
        varchar_100_ regulator
        datetime create_time
        datetime update_time
        int update_by
        tinyint is_del
        varchar_128_ category
    }
    tb_survey_question {
        int id
        int survey_id
        varchar_200_ p_key
        tinyint question_type
