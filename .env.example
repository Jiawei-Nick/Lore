# AWS Bedrock Bearer Token
# Get from your AWS Bedrock setup
AWS_BEARER_TOKEN_BEDROCK=your-aws-bearer-token-here

# AWS Region for Bedrock
AWS_REGION=us-east-1

# Lark App Credentials
# Create app at: https://open.feishu.cn/app (or https://open.larksuite.com/app)
LARK_APP_ID=cli_your-app-id
LARK_APP_SECRET=your-app-secret

# Lark Doc Configuration
# Folder Token: from URL https://xxx.feishu.cn/drive/folder/[FOLDER_TOKEN]
# This is the folder where new docs will be created
LARK_FOLDER_TOKEN=your-folder-token

# Parent Doc ID: from URL https://xxx.feishu.cn/docx/[DOC_ID]
# This is the parent doc where ERD will be updated
LARK_PARENT_DOC_ID=your-parent-doc-id
