# AWS Bedrock Credentials — set ONE of the two options below:

# Option A: Long-term IAM key pair (AWS Console → IAM → Users → Security credentials)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Option B: STS/SSO temporary session token (expires periodically)
# AWS_SESSION_TOKEN=FwoGZXIvYXdzE...

AWS_REGION=ap-southeast-1

# Lark App Credentials
# Create app at: https://open.larksuite.com/app
LARK_APP_ID=cli_your-app-id
LARK_APP_SECRET=your-app-secret

# Lark Folder Token: from URL https://xxx.feishu.cn/drive/folder/[FOLDER_TOKEN]
LARK_FOLDER_TOKEN=your-folder-token

# Lark Parent Doc ID: from URL https://xxx.feishu.cn/docx/[DOC_ID]
# Run `lore init-parent` to create one automatically if you don't have it
LARK_PARENT_DOC_ID=your-parent-doc-id
